{
  "name": "ftptransfer",
  "version": "1.0.0",
  "description": "A full-stack, lightweight web client built to seamlessly transfer images from your local machine to your remote FTP server (specifically tailored to bypass Hostinger Website Builder/CMS routing issues). It auto-generates immediately usable, public-facing URLs.",
  "main": "index.js",
  "scripts": {
    "start": "concurrently \"npm run dev:backend\" \"npm run dev:client\"",
    "dev:backend": "cd Backend && npm run dev",
    "dev:client": "cd Client && npm run dev",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cold-Juice911/FTPtransfer.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Cold-Juice911/FTPtransfer/issues"
  },
  "homepage": "https://github.com/Cold-Juice911/FTPtransfer#readme",
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.102.0",
    "bullmq": "^5.73.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.1",
    "express-rate-limit": "^8.3.2",
    "file-type": "^22.0.0",
    "ioredis": "^5.10.1",
    "lucide-react": "^1.7.0",
    "tailwind-merge": "^3.5.0"
  }
}
